# Carpeta de imágenes subidas desde el panel: servir imágenes, nunca ejecutar código.
php_flag engine off
<FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|cgi|sh)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
